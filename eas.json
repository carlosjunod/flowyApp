{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://tryflowy.app",
        "EXPO_PUBLIC_PB_URL": "https://pb.tryflowy.app",
        "EXPO_PUBLIC_R2_PUBLIC_URL": "https://files.tryflowy.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
